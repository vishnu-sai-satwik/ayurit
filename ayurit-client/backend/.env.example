# Backend Server Configuration
PORT=4000
NODE_ENV=production

# Database Provider: mongodb, postgres, or memory
# For development/testing, use memory (fallback if DB unavailable)
# For production, use mongodb or postgres with proper URI
DB_PROVIDER=mongodb

# MongoDB Atlas connection string
# Get from https://cloud.mongodb.com - create free cluster, then copy connection string
# Replace USERNAME, PASSWORD, and cluster details
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster-name.mongodb.net/ayurit_prod?retryWrites=true&w=majority

# PostgreSQL connection string (alternative to MongoDB)
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/ayurit_prod

# JWT Secret for token signing (minimum 32 characters)
JWT_SECRET=replace-with-strong-32-char-production-secret-minimum

# AES Secret for data encryption (minimum 32 bytes)
AES_SECRET=replace-with-32-byte-production-secret-minimum

# Integration API key for external EHR/HIS systems
INTEGRATION_API_KEY=replace-with-integration-key

# Google Gemini API key for AI-powered diet recommendations
API_KEY=your-gemini-api-key-here

# Cloud provider for file storage
CLOUD_PROVIDER=aws

# Frontend URL for CORS
ALLOWED_ORIGIN=https://yourdomain.com
